# App
APP_PORT=8080

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=xmeta_partner
DB_AUTO_MIGRATE=false
DB_RUN_MIGRATIONS=false

# AWS
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Admin Cognito (for admin management endpoints)
COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Partner Cognito (for partner authentication)
PARTNER_COGNITO_USER_POOL_ID=ap-northeast-1_yyyyyyyyy
PARTNER_COGNITO_CLIENT_ID=yyyyyyyyyyyyyyyyyyyyyyyyyy

# Internal API Key (for service-to-service communication)
INTERNAL_API_KEY=your-internal-api-key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# MinIO (Object Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=partner-assets
