# =============================================================================
# Partner API — environment template
# =============================================================================
# 1. Copy this file:                cp env.example .env
# 2. Fill in every value below.     nano .env
# 3. Confirm secrets stay secret.   .env is gitignored — keep it that way.
# =============================================================================

# ------- App -------
APP_PORT=8080
GIN_MODE=release

# ------- Database (PostgreSQL) -------
# DB_HOST is set automatically inside docker-compose (= postgres).
# Use the values below only when running the binary outside the compose stack.
DB_HOST=localhost
DB_PORT=5432
DB_USER=xmeta_partner
DB_PASSWORD=change-me-strong-password
DB_NAME=xmeta_partner
DB_TIMEZONE=Asia/Ulaanbaatar

# AutoMigrate runs GORM AutoMigrate (creates/alters tables based on structs).
# RunMigrations runs the idempotent SQL in database/migrations.go.
# Set both to "true" on first boot, "false" once schema is rolled out.
DB_AUTO_MIGRATE=true
DB_RUN_MIGRATIONS=true

# ------- AWS Cognito -------
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Admin Cognito pool — used by /admin/partner/* (back-office endpoints)
COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Partner Cognito pool — used by /partner/* (self-service portal)
PARTNER_COGNITO_USER_POOL_ID=ap-northeast-1_yyyyyyyyy
PARTNER_COGNITO_CLIENT_ID=yyyyyyyyyyyyyyyyyyyyyyyyyy

# ------- Internal API key -------
# Required header (X-Internal-API-Key) on /api/v1/internal/* endpoints.
# Rotate before going to production. Must match the value the monorepo uses
# when posting trade-event / link-referral / user-deposited events.
INTERNAL_API_KEY=rotate-me-32-byte-random-hex

# ------- CORS -------
# Comma-separated list of allowed origins. No trailing slashes.
ALLOWED_ORIGINS=https://partner.x-meta.com,https://admin.x-meta.com
